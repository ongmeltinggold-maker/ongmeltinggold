# nginx — reverse proxy พร้อม HTTPS
# วิธีใช้: วางใบรับรองไว้ที่ deploy/nginx/certs/fullchain.pem และ privkey.pem
#          แล้ว copy ไฟล์นี้ทับ nginx.conf:  cp nginx-https.conf.example nginx.conf
#          จากนั้น docker compose restart nginx
# ใบรับรอง: ใช้ Let's Encrypt (certbot) หรือใบรับรองที่ซื้อมา
upstream ong_web {
    server web:8000;
}

# HTTP → redirect ไป HTTPS (ยกเว้น ACME challenge สำหรับ certbot)
server {
    listen 80;
    server_name ong.example.com;   # << เปลี่ยนเป็นโดเมนจริง

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name ong.example.com;   # << เปลี่ยนเป็นโดเมนจริง

    ssl_certificate     /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 20m;

    location /static/ {
        alias /app/staticfiles/;
        expires 7d;
        access_log off;
    }
    location /media/ {
        alias /app/media/;
        expires 7d;
    }
    location / {
        proxy_pass http://ong_web;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_redirect off;
    }
}
