# ===========================================================================
# ONG หลอมทอง — ตัวแปรสภาพแวดล้อม production
# คัดลอกเป็น .env แล้วแก้ค่าให้เป็นของจริง:  cp .env.example .env
# *** ห้าม commit ไฟล์ .env จริงลง git ***
# ===========================================================================

# --- Django ---
# สร้าง key ใหม่:  python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=เปลี่ยน_เป็น_secret_key_สุ่มยาวๆ
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ong.example.com,www.ong.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://ong.example.com
# เปิด redirect เป็น https ที่ระดับ Django (ปกติให้ nginx จัดการ จึงปล่อย False)
DJANGO_SECURE_SSL_REDIRECT=False
# เปิด HSTS เมื่อ HTTPS นิ่งแล้ว (เช่น 2592000 = 30 วัน). ค่า 0 = ปิด
DJANGO_HSTS_SECONDS=0

# --- PostgreSQL ---
POSTGRES_DB=ong_prod
POSTGRES_USER=ong
POSTGRES_PASSWORD=เปลี่ยน_เป็นรหัสผ่านฐานข้อมูลที่แข็งแรง
POSTGRES_PORT=5432

# --- seed ครั้งแรก (ตั้ง 1 เฉพาะรอบแรกที่ต้องการ seed master data อัตโนมัติ) ---
RUN_SEED=0

# --- backup ---
BACKUP_HOUR=02          # ชั่วโมงที่สำรองข้อมูล (Asia/Bangkok) เช่น 02 = ตี 2
BACKUP_KEEP_DAYS=14     # เก็บไฟล์สำรองกี่วัน
